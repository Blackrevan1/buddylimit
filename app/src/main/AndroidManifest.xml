<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- See which apps the user can launch, for the app picker (Android 11+ package
         visibility). Broader visibility via QUERY_ALL_PACKAGES will come with the
         monitoring layer in a later M1 phase, if needed. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!--
        Later M1 phases will add: PACKAGE_USAGE_STATS, SYSTEM_ALERT_WINDOW,
        FOREGROUND_SERVICE (+ specialUse type), POST_NOTIFICATIONS,
        RECEIVE_BOOT_COMPLETED, REQUEST_IGNORE_BATTERY_OPTIMIZATIONS, QUERY_ALL_PACKAGES.
    -->

    <application
        android:name=".BuddyLimitApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BuddyLimit">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BuddyLimit">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
